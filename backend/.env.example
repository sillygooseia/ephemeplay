# EphemePlay backend — environment variables
# Copy this file to .env and fill in real values. .env is gitignored — never commit it.

# ── Server ────────────────────────────────────────────────────────────────────
PORT=8787

# ── Room settings ─────────────────────────────────────────────────────────────
# How long a room lives without activity (milliseconds). Default: 2 hours.
ROOM_TTL_MS=7200000

# ── Player identity JWTs (@epheme/core/deviceRegistry) ───────────────────────
# HS256 secret for signing 7-day player tokens. Generate with:
#   node -e "console.log(require('crypto').randomBytes(40).toString('base64url'))"
# Leave blank to disable JWT identity (players get anonymous random IDs instead).
PLAYER_JWT_SECRET="1rEA9xWWDEybpCQ5Kx8ZK1odFyLk-1F0n5t-jYDEdvlEuJe907nhbg"

# ── Redis (optional — all rate limiting and metrics degrade gracefully without it) ──
# e.g. redis://localhost:6379 or rediss://:<password>@your-host:6380
REDIS_URL=

# ── Rate limits (requests per minute per IP) ─────────────────────────────────
CREATE_ROOM_RATE_LIMIT=10
JOIN_ROOM_RATE_LIMIT=30
